                <span class="footer-btn-label ms-2">Configuración</span>
            </NavLink>

            <!-- Logout Link -->
            <NavLink class="footer-btn text-danger-hover d-flex align-items-center w-100" href="/logout-endpoint" title="Cerrar Sesión">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" style="flex-shrink: 0;"><path d="M12 3.25C12.4142 3.25 12.75 3.58579 12.75 4C12.75 4.41421 12.4142 4.75 12 4.75C7.99594 4.75 4.75 7.99594 4.75 12C4.75 16.0041 7.99594 19.25 12 19.25C12.4142 19.25 12.75 19.5858 12.75 20C12.75 20.4142 12.4142 20.75 12 20.75C7.16751 20.75 3.25 16.8325 3.25 12C3.25 7.16751 7.16751 3.25 12 3.25Z" fill="currentColor"></path><path d="M16.4697 9.53033C16.1768 9.23744 16.1768 8.76256 16.4697 8.46967C16.7626 8.17678 17.2374 8.17678 17.5303 8.46967L20.5303 11.4697C20.8232 11.7626 20.8232 12.2374 20.5303 12.5303L17.5303 15.5303C17.2374 15.8232 16.7626 15.8232 16.4697 15.5303C16.1768 15.2374 16.1768 14.7626 16.4697 14.4697L18.1893 12.75H10C9.58579 12.75 9.25 12.4142 9.25 12C9.25 11.5858 9.58579 11.25 10 11.25H18.1893L16.4697 9.53033Z" fill="currentColor"></path></svg>
                <span class="footer-btn-label ms-2">Cerrar Sesión</span>
            </NavLink>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <!-- Top Navigation -->
        <header class="top-navigation">
            <div class="d-flex align-items-center gap-2">
                @for (int i = 0; i < _breadcrumbs.Count; i++)
                {
                    var item = _breadcrumbs[i];
                    var isLast = i == _breadcrumbs.Count - 1;
                    if (i > 0)
                    {
                        <span style="color: var(--border-color); font-size: 13px;">></span>
                    }
                    if (isLast)
                    {
                        <span style="color: var(--text-primary); font-size: 14px; font-weight: 600;">@item</span>
                    }
                    else
                    {
                        <span style="color: var(--text-secondary); font-size: 14px;">@item</span>
                    }
                }
            </div>
            <div class="d-flex align-items-center gap-3">
                <!-- Search Icon -->
                <a href="/kb" class="btn btn-light p-0 rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: transparent; color: var(--text-secondary); text-decoration: none;" title="Buscar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </a>
                <CRM.WebFrontend.Client.Components.NotificationBell @rendermode="InteractiveServer" />
            </div>
        </header>

        <!-- Dynamic Page Body -->
        <div class="container-fluid py-2">
            @Body
        </div>

        <MudThemeProvider Theme="_customTheme" />
        <MudDialogProvider />
        <MudSnackbarProvider />
    </main>
</div>

<style>
    /* Collapse sidebar transitions */
    .custom-sidebar {
        transition: width 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), padding 0.3s ease, border-right 0.3s ease;
    }
</style>

@code {
    private bool _sidebarExpanded = false;
    private List<string> _breadcrumbs = new();

    private MudTheme _customTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#003B5C",
            Secondary = "#005F8D",
            AppbarBackground = "#003B5C",
            Background = "#F4F6F9",
            Surface = "#FFFFFF",
            TextPrimary = "#1D1F21",
            TextSecondary = "#5F6368",
            ActionDefault = "#003B5C",
            Info = "#005F8D",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444"
        }
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        UpdateBreadcrumbs();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateBreadcrumbs();
        StateHasChanged();
    }

    private void UpdateBreadcrumbs()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var segments = relativePath.Split('?', '#')[0].Split('/', StringSplitOptions.RemoveEmptyEntries);
        
        _breadcrumbs.Clear();
        _breadcrumbs.Add("Inicio");
        
        foreach (var seg in segments)
        {
            var clean = seg.ToLower() switch
            {
                "backoffice" => "Backoffice",
                "supervisor" => "Supervisor",
                "asesor" => "Asesor",
                "admin" => "Administración",
                "kb" => "Base de Conocimientos",
                "activations" => "Activaciones",
                "reports" => "Métricas y Reportes",
                "dashboard" => "Dashboard",
                "orders" => "Ventas",
                "new" => "Nueva Orden",
                "preventas" => "Pre-Ventas",
                "commissions" => "Comisiones",
                "equipo" => "Rendimiento de Equipo",
                "alertas" => "Alertas Activas",
                "incidents" => "Incidencias",
                "fields" => "Campos de Usuario",
                _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(seg.Replace("-", " "))
            };
            _breadcrumbs.Add(clean);
        }
        
        if (_breadcrumbs.Count == 1)
        {
            _breadcrumbs.Add("Dashboard");
        }
    }

    private void ToggleSidebar()
    {
        _sidebarExpanded = !_sidebarExpanded;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
