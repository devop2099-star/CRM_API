@inherits LayoutComponentBase

<div class="dashboard-root">
    <!-- Sidebar Left Panel -->
    <aside class="custom-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="logo-container">
            <div class="logo-g" @onclick="ToggleSidebar" title="Alternar Menú">G</div>
        </div>
        
        <div class="sidebar-menu">
            <NavMenu />
        </div>
        
        <!-- Bottom Sidebar profile avatar & settings -->
        <div class="sidebar-footer">
            <!-- Settings Icon Link -->
            <NavLink class="footer-btn" href="/settings" title="Configuración">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            </NavLink>
            <!-- Logout Icon Link -->
            <NavLink class="footer-btn text-danger-hover" href="/logout-endpoint" title="Cerrar Sesión">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
            </NavLink>
            
            <AuthorizeView>
                <Authorized>
                    <div class="avatar-container" 
                         title="@($"{context.User.Identity?.Name} ({string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role || c.Type == "roles").Select(c => c.Value))})")">
                        <span class="avatar-letter" style="color: #FFFFFF; font-weight: 700; font-size: 1rem;">
                            @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
                        </span>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <!-- Top Navigation -->
        <header class="top-navigation">
            <div class="d-flex align-items-center gap-3">
                <h4 class="m-0 font-weight-bold" style="font-weight: 700; font-size: 1.15rem; letter-spacing: -0.02em; color: var(--text-primary);">NYX CRM</h4>
            </div>
            <div class="d-flex align-items-center gap-3">
                <!-- Search Button (KB) -->
                <a href="/kb" class="btn btn-light p-0 rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: rgba(0,0,0,0.03); color: var(--text-secondary); text-decoration: none;" title="Base de Conocimientos (Buscar)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </a>
                <CRM.WebFrontend.Client.Components.NotificationBell />
                
                <div class="border-start h-50 mx-1 border-secondary border-opacity-10"></div>
                
                <AuthorizeView>
                    <Authorized>
                        <a href="/logout-endpoint" class="btn btn-primary btn-sm px-3 rounded-pill shadow-none" style="font-size: 0.775rem; height: 30px; font-weight: 600;">Cerrar Sesión</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-primary btn-sm px-3 rounded-pill shadow-none" style="font-size: 0.775rem; height: 30px; font-weight: 600;">Iniciar Sesión</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <!-- Dynamic Page Body -->
        <div class="container-fluid py-2">
            @Body
        </div>
    </main>
</div>

<style>
    /* Collapse sidebar transitions */
    .custom-sidebar {
        transition: width 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), padding 0.3s ease, border-right 0.3s ease;
    }
    .custom-sidebar.collapsed {
        width: 0px !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        border-right: none !important;
        overflow: hidden !important;
    }
</style>

@code {
    private bool _sidebarCollapsed = false;

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
