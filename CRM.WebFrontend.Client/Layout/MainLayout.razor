@inherits LayoutComponentBase

<div id="wrapper" class="@(_sidebarCollapsed ? "collapsed" : "")">
    <!-- Floating Logo Toggle Button -->
    <div id="sidebar-logo-container" @onclick="ToggleSidebar" class="d-flex align-items-center justify-content-center shadow-sm" title="Alternar Menú">
        <div class="rounded-circle bg-white text-dark d-flex align-items-center justify-content-center fw-bold" style="width: 38px; height: 38px; font-size: 1.25rem; user-select: none;">
            ✦
        </div>
    </div>

    <!-- Sidebar -->
    <div id="sidebar-wrapper">
        <!-- Spacer to make room for absolute logo -->
        <div style="height: 48px; width: 100%; flex-shrink: 0;"></div>
        
        <div class="flex-grow-1 w-100">
            <NavMenu />
        </div>
        
        <!-- Bottom Sidebar profile avatar & settings -->
        <div class="pt-3 border-top border-secondary border-opacity-10 w-100 d-flex flex-column align-items-center gap-2">
            <!-- Settings Icon Link -->
            <NavLink class="nav-link" href="/settings" title="Configuración">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            </NavLink>
            <!-- Logout Icon Link -->
            <NavLink class="nav-link text-danger-hover" href="/logout-endpoint" title="Cerrar Sesión">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
            </NavLink>
            
            <AuthorizeView>
                <Authorized>
                    <div class="rounded-circle bg-white text-dark d-flex align-items-center justify-content-center fw-bold shadow-sm" 
                         style="width: 38px; height: 38px; font-size: 1rem; cursor: pointer; transition: all 0.2s ease; margin-top: 4px;"
                         title="@($"{context.User.Identity?.Name} ({string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role || c.Type == "roles").Select(c => c.Value))})")">
                        @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Page Content -->
    <div id="page-content-wrapper">
        <header class="custom-header">
            <div class="d-flex align-items-center gap-3">
                <!-- Empty spacing since menu is toggled by clicking the logo -->
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <!-- Search & Notification Buttons with clean SVGs -->
                <button class="btn btn-light p-0 rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: rgba(0,0,0,0.03); color: var(--text-secondary);" title="Buscar">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </button>
                <CRM.WebFrontend.Client.Components.NotificationBell />
                
                <div class="border-start h-50 mx-1 border-secondary border-opacity-10"></div>
                
                <AuthorizeView>
                    <Authorized>
                        <a href="/logout-endpoint" class="btn btn-primary btn-sm px-3 rounded-pill shadow-none" style="font-size: 0.775rem; height: 30px;">Cerrar Sesión</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-primary btn-sm px-3 rounded-pill shadow-none" style="font-size: 0.775rem; height: 30px;">Iniciar Sesión</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="flex-grow-1 overflow-auto">
            <div class="container-fluid">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private bool _sidebarCollapsed = false;

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
