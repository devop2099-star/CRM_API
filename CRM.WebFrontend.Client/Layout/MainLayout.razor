@inherits LayoutComponentBase
@inject NavigationManager Navigation
@implements IDisposable

<div class="dashboard-root">
    <!-- Sidebar Left Panel -->
    <aside class="custom-sidebar @(_sidebarExpanded ? "expanded" : "")">
        <div class="logo-container">
            <div class="logo-g d-flex align-items-center justify-content-center" @onclick="ToggleSidebar" title="Expandir/Contraer Menú" style="cursor: pointer; user-select: none; width: 100%;">
                <img src="/images/logo.png" alt="NYX CRM Logo" style="width: 45px; height: 45px; object-fit: contain; transition: transform 0.2s ease;" />
            </div>
        </div>
        
        <div class="sidebar-menu">
            <NavMenu />
        </div>
        
        <!-- Bottom Sidebar profile avatar & settings -->
        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center justify-content-center w-100 mb-2" title="@context.User.Identity?.Name">
                        <div class="avatar-container flex-shrink-0" 
                             style="width: 38px; height: 38px; background: #E1F5FE; border: none; color: #003B5C; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.04);">
                            <span class="avatar-letter" style="font-weight: 700; font-size: 0.95rem;">
                                @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
                            </span>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            <!-- Settings Link -->
            <NavLink class="footer-btn d-flex align-items-center w-100" href="/settings" title="Configuración">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" style="flex-shrink: 0;"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 8.25C9.92893 8.25 8.25 9.92893 8.25 12C8.25 14.0711 9.92893 15.75 12 15.75C14.0711 15.75 15.75 14.0711 15.75 12C15.75 9.92893 14.0711 8.25 12 8.25ZM9.75 12C9.75 10.7574 10.7574 9.75 12 9.75C13.2426 9.75 14.25 10.7574 14.25 12C14.25 13.2426 13.2426 14.25 12 14.25C10.7574 14.25 9.75 13.2426 9.75 12Z" fill="currentColor"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M12 1.25C11.2954 1.25 10.6519 1.44359 9.94858 1.77037C9.26808 2.08656 8.48039 2.55304 7.49457 3.13685L6.74148 3.58283C5.75533 4.16682 4.96771 4.63324 4.36076 5.07944C3.73315 5.54083 3.25177 6.01311 2.90334 6.63212C2.55548 7.25014 2.39841 7.91095 2.32306 8.69506C2.24999 9.45539 2.24999 10.3865 2.25 11.556V12.444C2.24999 13.6135 2.24999 14.5446 2.32306 15.3049C2.39841 16.0891 2.55548 16.7499 2.90334 17.3679C3.25177 17.9869 3.73315 18.4592 4.36076 18.9206C4.96771 19.3668 5.75533 19.8332 6.74148 20.4172L7.4946 20.8632C8.48038 21.447 9.2681 21.9135 9.94858 22.2296C10.6519 22.5564 11.2954 22.75 12 22.75C12.7046 22.75 13.3481 22.5564 14.0514 22.2296C14.7319 21.9134 15.5196 21.447 16.5054 20.8632L17.2585 20.4172C18.2446 19.8332 19.0323 19.3668 19.6392 18.9206C20.2669 18.4592 20.7482 17.9869 21.0967 17.3679C21.4445 16.7499 21.6016 16.0891 21.6769 15.3049C21.75 14.5446 21.75 13.6135 21.75 12.4441V11.556C21.75 10.3866 21.75 9.45538 21.6769 8.69506C21.6016 7.91095 21.4445 7.25014 21.0967 6.63212C20.7482 6.01311 20.2669 5.54083 19.6392 5.07944C19.0323 4.63324 18.2447 4.16683 17.2585 3.58285L16.5054 3.13685C15.5196 2.55303 14.7319 2.08656 14.0514 1.77037C13.3481 1.44359 12.7046 1.25 12 1.25ZM8.22524 4.44744C9.25238 3.83917 9.97606 3.41161 10.5807 3.13069C11.1702 2.85676 11.5907 2.75 12 2.75C12.4093 2.75 12.8298 2.85676 13.4193 3.13069C14.0239 3.41161 14.7476 3.83917 15.7748 4.44744L16.4609 4.85379C17.4879 5.46197 18.2109 5.89115 18.7508 6.288C1