@inherits LayoutComponentBase

<div id="wrapper">
    <!-- Sidebar -->
    <div id="sidebar-wrapper">
        <div class="sidebar-heading d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <span class="me-2 fs-4 text-white">✦</span>
                <span class="fw-bold text-white fs-5 tracking-tight">NYX CRM</span>
            </div>
        </div>
        <div class="flex-grow-1">
            <NavMenu />
        </div>
        
        <!-- Bottom Sidebar Action (like Getting Started or Profile) -->
        <div class="pt-3 border-top border-secondary border-opacity-20 d-flex flex-column gap-2">
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center p-2 rounded-3 bg-white bg-opacity-10 text-white">
                        <div class="rounded-circle bg-white text-dark d-flex align-items-center justify-content-center me-2 fw-bold shadow-sm" style="width: 32px; height: 32px; font-size: 0.85rem;">
                            @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
                        </div>
                        <div class="overflow-hidden flex-grow-1" style="line-height: 1.2;">
                            <span class="d-block fw-semibold text-truncate" style="font-size: 0.8rem;">@context.User.Identity?.Name</span>
                            <small class="text-white-50 text-truncate d-block" style="font-size: 0.7rem;">@string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role || c.Type == "roles").Select(c => c.Value))</small>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- Page Content -->
    <div id="page-content-wrapper">
        <header class="custom-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light p-2 border-0 shadow-none" id="menu-toggle">
                    <span class="navbar-toggler-icon" style="width: 1.25em; height: 1.25em;"></span>
                </button>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <!-- Search & Notification Placeholders -->
                <button class="btn btn-light p-2 rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;" title="Buscar">
                    <span class="fs-6">🔍</span>
                </button>
                <button class="btn btn-light p-2 rounded-circle border-0 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;" title="Notificaciones">
                    <span class="fs-6">🔔</span>
                </button>
                
                <div class="border-start h-50 mx-1 border-secondary border-opacity-10"></div>
                
                <AuthorizeView>
                    <Authorized>
                        <a href="/logout-endpoint" class="btn btn-primary btn-sm px-4 rounded-pill shadow-none" style="font-size: 0.8rem; height: 36px;">Cerrar Sesión</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-primary btn-sm px-4 rounded-pill shadow-none" style="font-size: 0.8rem; height: 36px;">Iniciar Sesión</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="flex-grow-1 overflow-auto p-4 p-xl-5">
            @Body
        </main>
    </div>
</div>
