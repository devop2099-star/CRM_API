@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using CRM.WebFrontend.Client.Models
@using CRM.WebFrontend.Client.Services
@rendermode InteractiveServer
@inject NotificationService NotifService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="notification-bell-wrapper position-relative" tabindex="-1" @onfocusout="OnFocusOut">
    <button class="btn btn-light p-2 rounded-circle border-0 d-flex align-items-center justify-content-center notification-bell-btn @(isOpen ? "active" : "")"
            style="width: 38px; height: 38px;"
            title="Notificaciones"
            @onclick="TogglePanel"
            @onclick:stopPropagation="true">
        <span class="fs-6">🔔</span>
        @if (unreadCount > 0)
        {
            <span class="notification-badge">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
        }
    </button>

    @if (isOpen)
    {
        <div class="notification-panel shadow-lg rounded-4 border">
            <!-- Header -->
            <div class="notification-panel-header d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-bold" style="font-size: 0.95rem;">Notificaciones</span>
                @if (unreadCount > 0)
                {
                    <button class="btn btn-link btn-sm text-primary text-decoration-none p-0"
                            style="font-size: 0.78rem;"
                            @onclick="MarkAllRead"
                            @onclick:stopPropagation="true">
                        Marcar todo como leído
                    </button>
                }
            </div>

            <!-- Body -->
            <div class="notification-panel-body">
                @if (isLoading && notifications.Count == 0)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <p class="text-muted small mt-2 mb-0">Cargando...</p>
                    </div>
                }
                else if (notifications.Count == 0)
                {
                    <div class="text-center py-5">
                        <span style="font-size: 2.5rem; opacity: 0.3;">🔔</span>
                        <p class="text-muted small mt-2 mb-0">Sin notificaciones</p>
                    </div>
                }
                else
                {
                    @foreach (var notif in notifications)
                    {
                        <div class="notification-item d-flex align-items-start gap-2 px-3 py-2 border-bottom @(notif.IsRead ? "read" : "unread")"
                             role="button"
                             @onclick="() => OnNotificationClick(notif)"
                             @onclick:stopPropagation="true">
                            <div class="notification-icon flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle mt-1"
                                 style="width: 32px; height: 32px; background: #f0f4ff; font-size: 0.9rem;">
                                @notif.ModuleIcon
                            </div>
                            <div class="flex-grow-1 overflow-hidden" style="line-height: 1.3;">
                                <div class="d-flex justify-content-between align-items-start">
                                    <span class="fw-semibold text-truncate d-block" style="font-size: 0.82rem;">@notif.Title</span>
                                    <span class="text-muted flex-shrink-0 ms-2" style="font-size: 0.68rem;">@notif.TimeAgo</span>
                                </div>
                                <span class="text-muted d-block text-truncate" style="font-size: 0.75rem;">@notif.Message</span>
                            </div>
                            @if (!notif.IsRead)
                            {
                                <div class="flex-shrink-0 mt-2">
                                    <span class="d-inline-block rounded-circle bg-primary" style="width: 8px; height: 8px;"></span>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<!-- Modal de Detalle -->
@if (_showDetailModal && _selectedNotification != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="fw-bold mb-0">Detalle de Notificación</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailModal"></button>
                </div>
                <div class="modal-body py-4">
                    <h6 class="fw-bold text-dark mb-2">@_selectedNotification.Title</h6>
                    <p class="text-muted mb-4" style="font-size: 0.95rem; white-space: pre-wrap;">
                        @_selectedNotification.Message
                    </p>
                    <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                        <span class="badge bg-light text-dark border">
                            @(_selectedNotification.Module ?? "SISTEMA")
                        </span>
                        <span class="text-muted">
                            @_selectedNotification.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 d-flex justify-content-end gap-2">
                    <button class="btn btn-light" @onclick="CloseDetailModal">Cerrar</button>
                    @if (!string.IsNullOrEmpty(ResolveNavigationRoute(_selectedNotification)))
                    {
                        <button class="btn btn-dark" @onclick="NavigateToSelected">
                            Ver en el sistema
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .notification-bell-wrapper {
        z-index: 1050;
    }
    .notification-bell-btn {
        transition: background-color 0.2s ease, transform 0.15s ease;
    }
    .notification-bell-btn:hover, .notification-bell-btn.active {
        background-color: #e9ecef !important;
        transform: scale(1.05);
    }
    .notification-badge {
        position: absolute;
        top: 2px;
        right: 0px;
        background: #ef4444;
        color: white;
        font-size: 0.6rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        line-height: 1;
        border: 2px solid white;
        animation: badge-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @@keyframes badge-pop {
        0% { transform: scale(0); }
        100% { transform: scale(1); }
    }

    .notification-panel {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 360px;
        max-height: 420px;
        background: white;
        z-index: 1060;
        display: flex;
        flex-direction: column;
        animation: panel-slide-in 0.2s ease-out forwards;
        overflow: hidden;
    }
    @@keyframes panel-slide-in {
        0% { opacity: 0; transform: translateY(-8px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    .notification-panel-header {
        background: #fafbfd;
    }

    .notification-panel-body {
        overflow-y: auto;
        max-height: 360px;
        scrollbar-width: thin;
    }

    .notification-item {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }
    .notification-item:hover {
        background-color: #f5f7fa;
    }
    .notification-item.unread {
        background-color: #f0f6ff;
    }
    .notification-item.unread:hover {
        background-color: #e4eefb;
    }
    .notification-item.read {
        background-color: #ffffff;
        opacity: 0.75;
    }
    .notification-item.read:hover {
        background-color: #f8fafc;
        opacity: 0.95;
    }
    .notification-item:last-child {
        border-bottom: none !important;
    }

    @@media (max-width: 576px) {
        .notification-panel {
            width: calc(100vw - 24px);
            right: -60px;
        }
    }
</style>

@code {
    private List<NotificationDto> notifications = new();
    private int unreadCount = 0;
    private bool isOpen = false;
    private bool isLoading = false;
    private long currentUserId = 0;
    private string userRole = string.Empty;
    private string? accessToken;
    private Timer? pollingTimer;

    private NotificationDto? _selectedNotification;
    private bool _showDetailModal = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var idStr = user.FindFirst("id_user")?.Value
                    ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                    ?? user.FindFirst("sub")?.Value;
        currentUserId = long.TryParse(idStr, out var id) ? id : 0;
        accessToken = user.FindFirst("access_token")?.Value;

        userRole = user.FindFirst(ClaimTypes.Role)?.Value 
                   ?? user.FindFirst("role")?.Value 
                   ?? "";

        if (currentUserId > 0)
        {
            await RefreshNotificationsAsync();

            // Polling every 30 seconds
            pollingTimer = new Timer(async _ =>
            {
                await RefreshNotificationsAsync();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private async Task RefreshNotificationsAsync()
    {
        if (currentUserId <= 0) return;

        try
        {
            if (string.IsNullOrEmpty(accessToken))
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                accessToken = authState.User.FindFirst("access_token")?.Value;
            }

            var serverNotifications = await NotifService.GetRecentAsync(currentUserId, accessToken);

            notifications = serverNotifications.ToList();
            unreadCount = notifications.Count(n => !n.IsRead);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NotificationBell] Refresh error: {ex.Message}");
        }
    }

    private void TogglePanel()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            _ = RefreshNotificationsAsync();
        }
    }

    private async Task OnFocusOut(FocusEventArgs e)
    {
        // Retardo para permitir que se registre un clic interno (OnNotificationClick)
        // antes de cerrar el panel y removerlo del DOM
        await Task.Delay(150);
        if (isOpen)
        {
            isOpen = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnNotificationClick(NotificationDto notif)
    {
        if (!notif.IsRead)
        {
            await NotifService.MarkAsReadAsync(notif.IdAlert, accessToken);
            notif.IsRead = true;
            unreadCount = notifications.Count(n => !n.IsRead);
        }

        isOpen = false;
        _selectedNotification = notif;
        _showDetailModal = true;
    }

    private void CloseDetailModal()
    {
        _showDetailModal = false;
        _selectedNotification = null;
    }

    private void NavigateToSelected()
    {
        if (_selectedNotification != null)
        {
            var route = ResolveNavigationRoute(_selectedNotification);
            CloseDetailModal();
            if (!string.IsNullOrEmpty(route))
            {
                NavManager.NavigateTo(route);
            }
        }
    }

    private async Task MarkAllRead()
    {
        await NotifService.MarkAllAsReadAsync(currentUserId, accessToken);
        foreach (var n in notifications)
        {
            n.IsRead = true;
        }
        unreadCount = 0;
    }

    private string? ResolveNavigationRoute(NotificationDto notif)
    {
        var module = notif.Module?.ToUpperInvariant() ?? "";
        var actionData = notif.ActionData ?? "";

        // Si la notificación es de una incidencia, enrutar según el rol
        if (module.Contains("INCIDENT") || module.Contains("INCIDENCIA"))
        {
            if (userRole.Equals("SUPERVISOR", StringComparison.OrdinalIgnoreCase))
            {
                return "/supervisor/dashboard";
            }
            else if (userRole.Equals("ASESOR", StringComparison.OrdinalIgnoreCase))
            {
                return !string.IsNullOrEmpty(actionData) ? $"/asesor/orders/{actionData}" : "/asesor/orders";
            }
            
            // Default para Backoffice o cualquier otro rol
            return "/backoffice/incidents";
        }

        return module switch
        {
            "ORDER" or "SALES" => userRole.Equals("SUPERVISOR", StringComparison.OrdinalIgnoreCase)
                ? (!string.IsNullOrEmpty(actionData) ? $"/supervisor/orders/{actionData}" : "/supervisor/dashboard")
                : userRole.Equals("BACKOFFICE", StringComparison.OrdinalIgnoreCase)
                    ? "/backoffice/dashboard"
                    : (!string.IsNullOrEmpty(actionData) ? $"/asesor/orders/{actionData}" : "/asesor/orders"),
            "BACKOFFICE" or "BAC" => "/backoffice/dashboard",
            "SUPERVISOR" => "/supervisor/dashboard",
            "TRANSFER" or "TRANSFERENCIA" => "/supervisor/dashboard",
            "AUDIT" or "AUDITORIA" => "/backoffice/dashboard",
            _ => null
        };
    }

    public void Dispose()
    {
        pollingTimer?.Dispose();
    }
}
