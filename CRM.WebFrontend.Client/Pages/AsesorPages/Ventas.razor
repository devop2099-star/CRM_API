@page "/asesor/ventas"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "ASESOR")]
@inject HttpClient Http

<PageTitle>Mis Ventas - NYX CRM</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary mb-1">Mis Ventas</h2>
            <p class="text-muted mb-0">Historial y seguimiento de tus ventas completadas.</p>
        </div>
    </div>

    <!-- Filtros (Visuales) -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Buscar por Cliente</label>
                    <input type="text" class="form-control rounded-3" placeholder="Nombre del cliente..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Mes</label>
                    <input type="month" class="form-control rounded-3" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Estado</label>
                    <select class="form-select rounded-3">
                        <option value="">Todos</option>
                        <option value="Aprobado">Aprobado</option>
                        <option value="Pendiente">Pendiente</option>
                    </select>
                </div>
            </div>
            <div class="mt-3 text-end">
                <button class="btn btn-outline-secondary rounded-pill px-4 me-2">Limpiar</button>
                <button class="btn btn-primary rounded-pill px-4">Buscar</button>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 py-3">ID Venta</th>
                            <th class="py-3">Fecha</th>
                            <th class="py-3">Cliente</th>
                            <th class="py-3">Monto</th>
                            <th class="py-3">Estado</th>
                            <th class="pe-4 py-3 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    Cargando ventas...
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    No se encontraron ventas para este período.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await Task.Delay(500); // Simulando carga mientras se integra el endpoint
        // Aquí iría la carga real desde el API
        isLoading = false;
    }
}
