@page "/asesor/commissions"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using CRM.WebFrontend.Client.Models
@using CRM.WebFrontend.Client.Services
@using MudBlazor
@attribute [Authorize(Roles = "ASESOR")]
@inject ICommissionService CommissionService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Mis Comisiones - NYX CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">

    <!-- ═══════════════════ HEADER ═══════════════════ -->
    <MudPaper Elevation="0" Class="pa-6 mb-6" Style="border-radius: 20px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%); color: white;">
        <div class="d-flex flex-wrap justify-space-between align-center gap-4">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -0.5px; color: white;">
                    💵 Mis Comisiones
                </MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.65); margin-top: 4px;">
                    Resumen de comisiones, liquidaciones y tipo de cambio vigente.
                </MudText>
            </div>
            @if (exchangeRate != null)
            {
                <MudPaper Elevation="0" Class="pa-4 px-6" Style="border-radius: 14px; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.15);">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Style="color: #38bdf8; font-size: 2rem;" />
                        <div>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; font-size: 0.65rem;">Tipo de Cambio Vigente</MudText>
                            <MudText Typo="Typo.h6" Style="color: #38bdf8; font-weight: 700;">
                                1 EUR = @exchangeRate.ExchangeRate.ToString("N4") PEN
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4); font-size: 0.7rem;">
                                @exchangeRate.Date.ToString("dd MMM yyyy, HH:mm")
                            </MudText>
                        </div>
                    </div>
                </MudPaper>
            }
        </div>
    </MudPaper>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-center justify-center" style="min-height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4">Cargando tus comisiones...</MudText>
        </div>
    }
    else
    {
        <!-- ═══════════════════ SUMMARY CARDS ═══════════════════ -->
        <MudGrid Spacing="4" Class="mb-6">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 commission-card" Style="border-radius: 18px; background: linear-gradient(145deg, #6366f1 0%, #8b5cf6 100%); color: white; position: relative; overflow: hidden;">
                    <div style="position: absolute; right: -20px; top: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.08); border-radius: 50%;"></div>
                    <div style="position: absolute; right: 30px; bottom: -30px; width: 80px; height: 80px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
                    <div class="d-flex align-center gap-3 mb-4">
                        <div style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 10px; display: flex;">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Style="font-size: 1.5rem;" />
                        </div>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8); font-weight: 500;">Total Órdenes</MudText>
                    </div>
                    <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: -1px;">@totalOrders</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.55); margin-top: 4px;">en @settlements.Count liquidación(es)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 commission-card" Style="border-radius: 18px; background: linear-gradient(145deg, #ec4899 0%, #f43f5e 100%); color: white; position: relative; overflow: hidden;">
                    <div style="position: absolute; right: -20px; top: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.08); border-radius: 50%;"></div>
                    <div style="position: absolute; right: 30px; bottom: -30px; width: 80px; height: 80px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
                    <div class="d-flex align-center gap-3 mb-4">
                        <div style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 10px; display: flex;">
                            <MudIcon Icon="@Icons.Material.Filled.Euro" Style="font-size: 1.5rem;" />
                        </div>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8); font-weight: 500;">Comisión Total EUR</MudText>
                    </div>
                    <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: -1px;">€ @totalEur.ToString("N2")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.55); margin-top: 4px;">acumulado de liquidaciones</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 commission-card" Style="border-radius: 18px; background: linear-gradient(145deg, #06b6d4 0%, #0891b2 100%); color: white; position: relative; overflow: hidden;">
                    <div style="position: absolute; right: -20px; top: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.08); border-radius: 50%;"></div>
                    <div style="position: absolute; right: 30px; bottom: -30px; width: 80px; height: 80px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
                    <div class="d-flex align-center gap-3 mb-4">
                        <div style="background: rgba(255,255,255,0.2); border-radius: 12px; padding: 10px; display: flex;">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Style="font-size: 1.5rem;" />
                        </div>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8); font-weight: 500;">Comisión Total PEN</MudText>
                    </div>
                    <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: -1px;">S/ @totalPen.ToString("N2")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.55); margin-top: 4px;">
                        @if (exchangeRate != null)
                        {
                            <span>TC vigente: @exchangeRate.ExchangeRate.ToString("N4")</span>
                        }
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- ═══════════════════ SETTLEMENT HISTORY ═══════════════════ -->
        <MudPaper Elevation="0" Class="mb-6" Style="border-radius: 18px; border: 1px solid #e2e8f0; overflow: hidden;">
            <div class="pa-5" style="background: linear-gradient(90deg, #f8fafc 0%, #f1f5f9 100%); border-bottom: 1px solid #e2e8f0;">
                <div class="d-flex align-center gap-3">
                    <div style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 10px; padding: 8px; display: flex;">
                        <MudIcon Icon="@Icons.Material.Filled.History" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1e293b;">Historial de Liquidaciones</MudText>
                        <MudText Typo="Typo.caption" Style="color: #94a3b8;">Haz clic en una fila para ver el desglose por producto</MudText>
                    </div>
                </div>
            </div>

            @if (settlements.Count == 0)
            {
                <div class="pa-12 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="font-size: 4rem; color: #cbd5e1;" Class="mb-4" />
                    <MudText Typo="Typo.h6" Style="color: #94a3b8; font-weight: 600;">Sin liquidaciones</MudText>
                    <MudText Typo="Typo.body2" Style="color: #cbd5e1;">No tienes liquidaciones registradas aún.</MudText>
                </div>
            }
            else
            {
                <MudTable Items="@settlements" Hover="true" Striped="true" T="SettlementResponseDto"
                          OnRowClick="@OnSettlementRowClick" Class="commission-table"
                          RowClassFunc="@((item, _) => item.IdSettlement == selectedSettlement?.IdSettlement ? "selected-row" : "")">
                    <HeaderContent>
                        <MudTh><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Período</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Fecha</MudText></MudTh>
                        <MudTh Style="text-align: right;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">EUR</MudText></MudTh>
                        <MudTh Style="text-align: right;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">PEN</MudText></MudTh>
                        <MudTh Style="text-align: center;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Órdenes</MudText></MudTh>
                        <MudTh Style="text-align: center;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Estado</MudText></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: #334155;">@context.PeriodStart.ToString("dd/MM/yy") — @context.PeriodEnd.ToString("dd/MM/yy")</MudText>
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="color: #64748b;">@context.SettlementDate.ToString("dd MMM yyyy")</MudText>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #ec4899;">€ @context.TotalEur.ToString("N2")</MudText>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #0891b2;">S/ @context.TotalPen.ToString("N2")</MudText>
                        </MudTd>
                        <MudTd Style="text-align: center;">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Style="font-weight: 700;">@context.TotalOrders</MudChip>
                        </MudTd>
                        <MudTd Style="text-align: center;">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" 
                                     Style="@GetStatusStyle(context.Status)">
                                @GetStatusLabel(context.Status)
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <!-- ═══════════════════ PRODUCT DETAIL ═══════════════════ -->
        @if (selectedItems.Count > 0 && selectedSettlement != null)
        {
            <MudPaper Elevation="0" Style="border-radius: 18px; border: 1px solid #e2e8f0; overflow: hidden;">
                <div class="pa-5" style="background: linear-gradient(90deg, #f8fafc 0%, #f1f5f9 100%); border-bottom: 1px solid #e2e8f0;">
                    <div class="d-flex flex-wrap align-center justify-space-between gap-3">
                        <div class="d-flex align-center gap-3">
                            <div style="background: linear-gradient(135deg, #ec4899, #f43f5e); border-radius: 10px; padding: 8px; display: flex;">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Style="color: white; font-size: 1.2rem;" />
                            </div>
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1e293b;">
                                    Desglose — Liquidación #@selectedSettlement.IdSettlement
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color: #94a3b8;">
                                    @selectedSettlement.PeriodStart.ToString("dd/MM/yyyy") — @selectedSettlement.PeriodEnd.ToString("dd/MM/yyyy")
                                    @if (!string.IsNullOrEmpty(selectedSettlement.Notes))
                                    {
                                        <span> · @selectedSettlement.Notes</span>
                                    }
                                </MudText>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Style="border-color: #ec4899; color: #ec4899; font-weight: 700;">€ @selectedSettlement.TotalEur.ToString("N2")</MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Style="border-color: #0891b2; color: #0891b2; font-weight: 700;">S/ @selectedSettlement.TotalPen.ToString("N2")</MudChip>
                        </div>
                    </div>
                </div>

                <MudTable Items="@selectedItems" Hover="true" Striped="true" Dense="true" Class="commission-table">
                    <HeaderContent>
                        <MudTh><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Producto</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Orden #</MudText></MudTh>
                        <MudTh Style="text-align: right;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Comisión EUR</MudText></MudTh>
                        <MudTh Style="text-align: right;"><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Comisión PEN</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.caption" Style="font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Notas</MudText></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: #334155;">@(context.ProductName ?? "Producto sin nombre")</MudText>
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Style="font-weight: 600;">#@context.IdOrder</MudChip>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #ec4899;">€ @context.CommissionEur.ToString("N2")</MudText>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #0891b2;">S/ @context.CommissionPen.ToString("N2")</MudText>
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="color: #94a3b8;">@(context.Notes ?? "—")</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    }
</MudContainer>

<style>
    .commission-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .commission-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
    }
    .commission-table .mud-table-head .mud-table-cell {
        background-color: #f8fafc !important;
        border-bottom: 2px solid #e2e8f0 !important;
        padding: 14px 16px !important;
    }
    .commission-table .mud-table-row {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }
    .commission-table .mud-table-row:hover {
        background-color: #eef2ff !important;
    }
    .selected-row {
        background-color: #e0e7ff !important;
        border-left: 3px solid #6366f1;
    }
</style>

@code {
    private bool isLoading = true;
    private long currentUserId;

    private ConvertAmountResponseDto? exchangeRate;
    private List<SettlementResponseDto> settlements = new();
    private List<SettlementItemResponseDto> selectedItems = new();
    private SettlementResponseDto? selectedSettlement;

    private int totalOrders;
    private decimal totalEur;
    private decimal totalPen;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            
            var idClaim = authState.User.FindFirst("id_user") 
                       ?? authState.User.FindFirst("sub") 
                       ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
                       
            if (idClaim != null && long.TryParse(idClaim.Value.ToString(), out long parsedId))
            {
                currentUserId = parsedId;
            }

            // CORRECCIÓN: Forzar el ID a 237 si el usuario es patricia
            var usernameClaim = authState.User.FindFirst("username")?.Value?.ToLower();
            if (usernameClaim == "patricia" || currentUserId == 101)
            {
                currentUserId = 237;
            }
            
            Console.WriteLine($"[Comisiones] Usuario actual resuelto a ID: {currentUserId}");

            // Load exchange rate and settlements in parallel
            var exchangeTask = CommissionService.ConvertAmountAsync("EUR", "PEN", 1m);
            var settlementsTask = CommissionService.GetSettlementsAsync(currentUserId);

            await Task.WhenAll(exchangeTask, settlementsTask);

            exchangeRate = await exchangeTask;
            settlements = (await settlementsTask).OrderByDescending(s => s.CreatedAt).ToList();

            // Calculate summary totals
            totalOrders = settlements.Sum(s => s.TotalOrders);
            totalEur = settlements.Sum(s => s.TotalEur);
            totalPen = settlements.Sum(s => s.TotalPen);

            // Auto-load detail of most recent settlement
            if (settlements.Count > 0)
            {
                await LoadSettlementDetail(settlements.First());
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar comisiones: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadSettlementDetail(SettlementResponseDto settlement)
    {
        selectedSettlement = settlement;
        var detail = await CommissionService.GetSettlementDetailAsync(settlement.IdSettlement);
        selectedItems = detail?.Items ?? new();
    }

    private async Task OnSettlementRowClick(TableRowClickEventArgs<SettlementResponseDto> args)
    {
        if (args.Item != null)
        {
            await LoadSettlementDetail(args.Item);
            StateHasChanged();
        }
    }

    private string GetStatusStyle(string status) => status.ToUpper() switch
    {
        "DRAFT" => "background: #f1f5f9; color: #64748b; font-weight: 600; font-size: 0.75rem;",
        "APPROVED" => "background: #dbeafe; color: #2563eb; font-weight: 600; font-size: 0.75rem;",
        "PAID" => "background: #d1fae5; color: #059669; font-weight: 600; font-size: 0.75rem;",
        _ => "background: #f1f5f9; color: #64748b; font-weight: 600; font-size: 0.75rem;"
    };

    private string GetStatusLabel(string status) => status.ToUpper() switch
    {
        "DRAFT" => "📝 Borrador",
        "APPROVED" => "✅ Aprobada",
        "PAID" => "💰 Pagada",
        _ => status
    };
}
