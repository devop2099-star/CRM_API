@page "/asesor/orders"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "ASESOR")]
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@using System.Net.Http.Json
@using MudBlazor
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Mis Ventas - NYX CRM</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary mb-1">Mis Órdenes de Venta</h2>
            <p class="text-muted mb-0">Gestiona y haz seguimiento a tus ventas realizadas.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a href="/asesor/orders/new" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-plus-circle me-2"></i> + Nueva Orden
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Estado</label>
                    <select class="form-select rounded-3" @bind="filterStatusId">
                        <option value="">Todos</option>
                        @foreach (var st in filterStatuses)
                        {
                            <option value="@st.Id">@st.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Campaña</label>
                    <select class="form-select rounded-3" @bind="filterCampaignId">
                        <option value="">Todas</option>
                        @foreach (var c in filterCampaigns)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Desde</label>
                    <input type="date" class="form-control rounded-3" @bind="filterDateFrom" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small">Hasta</label>
                    <input type="date" class="form-control rounded-3" @bind="filterDateTo" />
                </div>
            </div>
            <div class="mt-3 text-end">
                <button class="btn btn-outline-secondary rounded-pill px-4 me-2" @onclick="ClearFilters">Limpiar</button>
                <button class="btn btn-dark rounded-pill px-4" @onclick="ApplyFilters">Buscar</button>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 py-3">N° Orden</th>
                            <th>Cliente</th>
                            <th>Campaña</th>
                            <th>Estado</th>
                            <th>Substatus</th>
                            <th>Fecha</th>
                            <th>Días</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Cargando...</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (!pagedOrders.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    No se encontraron órdenes con los filtros seleccionados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in pagedOrders)
                            {
                                <tr style="cursor: pointer;" @onclick="() => GoToDetail(order.IdOrder)">
                                    <td class="ps-4 fw-bold text-primary">#@order.IdOrder</td>
                                    <td class="fw-medium">@order.ClientName</td>
                                    <td><span class="badge bg-light text-dark border">@order.CampaignName</span></td>
                                    <td>
                                        <span class="badge rounded-pill px-3" style="background-color: @(order.StatusColor ?? "#6c757d"); color: #fff;">
                                            @order.StatusName
                                        </span>
                                    </td>
                                    <td class="text-muted small">@(string.IsNullOrEmpty(order.SubstatusName) ? "-" : order.SubstatusName)</td>
                                    <td>@order.SalesDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="fw-bold @(order.DaysElapsed > 5 ? "text-danger" : "text-success")">
                                            @order.DaysElapsed días
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Paginación -->
            @if (totalPages > 1)
            {
                <div class="d-flex justify-content-center p-3 border-top">
                    <nav aria-label="Navegación de páginas">
                        <ul class="pagination mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Anterior</button>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(pageNum)">@pageNum</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Siguiente</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

@if (selectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-primary">Detalle de Orden #@selectedOrder.IdOrder</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Cliente</span>
                            <span class="d-block fw-medium">@selectedOrder.ClientName</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Campaña</span>
                            <span class="d-block fw-medium">@selectedOrder.CampaignName</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Estado</span>
                            <span class="badge rounded-pill px-3 mt-1" style="background-color: @(selectedOrder.StatusColor ?? "#6c757d"); color: #fff;">
                                @selectedOrder.StatusName
                            </span>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Substatus</span>
                            <span class="d-block">@(string.IsNullOrEmpty(selectedOrder.SubstatusName) ? "-" : selectedOrder.SubstatusName)</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Fecha</span>
                            <span class="d-block">@selectedOrder.SalesDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="d-block text-muted small fw-bold">Días Transcurridos</span>
                            <span class="fw-bold @(selectedOrder.DaysElapsed > 5 ? "text-danger" : "text-success")">
                                @selectedOrder.DaysElapsed días
                            </span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="CloseDetail">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class SalesOrderListDto
    {
        public long IdOrder { get; set; }
        public long IdCmpg { get; set; }
        public long? IdStatus { get; set; }
        public long IdLead { get; set; }
        public string ClientName { get; set; } = "";
        public string CampaignName { get; set; } = "";
        public string StatusName { get; set; } = "";
        public string? StatusColor { get; set; }
        public string? SubstatusName { get; set; }
        public DateTime SalesDate { get; set; }
        public int DaysElapsed { get; set; }
    }

    public class LookupDto { public long Id { get; set; } public string Name { get; set; } = ""; public string? Color { get; set; } }

    private List<SalesOrderListDto> allOrders = new();
    private List<SalesOrderListDto> pagedOrders = new();
    private SalesOrderListDto? selectedOrder;
    
    private List<LookupDto> filterStatuses = new();
    private List<LookupDto> filterCampaigns = new();

    private bool isLoading = true;
    private int currentUserId = 0;

    // Filtros
    private long? filterStatusId;
    private long? filterCampaignId;
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;

    // Paginación
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((double)allOrders.Count / pageSize);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdStr = user.FindFirst("id_user")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out int uid))
            {
                currentUserId = uid;
            }
        }
        await LoadFilterOptionsAsync();
        await LoadOrdersAsync();
    }

    private async Task LoadFilterOptionsAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            
            // Cargar campañas
            var campaignsResult = await client.GetFromJsonAsync<List<CRM.WebFrontend.Client.Models.CampaignDto>>("/api/campaigns");
            if (campaignsResult != null)
            {
                filterCampaigns = campaignsResult.Select(c => new LookupDto { Id = c.Id, Name = c.Name }).ToList();
            }

            // Cargar estados (usando id de campaña = 1 como pivote base para extraer el catálogo general según el backend)
            var statusesResult = await client.GetFromJsonAsync<List<CRM.WebFrontend.Client.Models.OrderStatusDto>>("/api/campaigns/1/statuses");
            if (statusesResult != null)
            {
                filterStatuses = statusesResult.Select(s => new LookupDto { Id = s.Id, Name = s.Name, Color = s.Color }).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading filter options: {ex.Message}");
        }
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            
            var query = $"/api/orders?userId={currentUserId}";
            if (filterStatusId.HasValue) query += $"&statusId={filterStatusId}";
            if (filterCampaignId.HasValue) query += $"&campaignId={filterCampaignId}";
            if (filterDateFrom.HasValue) query += $"&dateFrom={filterDateFrom.Value:yyyy-MM-dd}";
            if (filterDateTo.HasValue) query += $"&dateTo={filterDateTo.Value:yyyy-MM-dd}";

            var result = await client.GetFromJsonAsync<List<SalesOrderListDto>>(query);
            if (result != null)
            {
                foreach (var o in result)
                {
                    o.CampaignName = filterCampaigns.FirstOrDefault(c => c.Id == o.IdCmpg)?.Name ?? "Desconocida";
                    var matchedStatus = filterStatuses.FirstOrDefault(s => s.Id == o.IdStatus);
                    o.StatusName = matchedStatus?.Name ?? "Por Asignar";
                    o.StatusColor = matchedStatus?.Color ?? "#6c757d";
                    o.ClientName = !string.IsNullOrEmpty(o.ClientName) ? o.ClientName : $"Cliente Lead #{o.IdLead}";
                }

                // Fetch real lead names from Lead API
                var uniqueLeadIds = result.Select(o => o.IdLead).Distinct().ToList();
                foreach (var leadId in uniqueLeadIds)
                {
                    try
                    {
                        var leadData = await client.GetFromJsonAsync<System.Text.Json.JsonElement>($"/api/leads/{leadId}");
                        string fName = leadData.GetProperty("firstName").GetString() ?? "";
                        string lName = leadData.GetProperty("lastName").GetString() ?? "";
                        string realName = $"{fName} {lName}".Trim();
                        if (!string.IsNullOrEmpty(realName))
                        {
                            foreach (var o in result.Where(x => x.IdLead == leadId))
                            {
                                o.ClientName = realName;
                            }
                        }
                    }
                    catch { /* ignore, keep original ClientName if not found */ }
                }

                allOrders = result;
                UpdatePagedOrders();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching orders: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadOrdersAsync();
    }

    private async Task ClearFilters()
    {
        filterStatusId = null;
        filterCampaignId = null;
        filterDateFrom = null;
        filterDateTo = null;
        currentPage = 1;
        await LoadOrdersAsync();
    }

    private void UpdatePagedOrders()
    {
        pagedOrders = allOrders.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    }

    private void ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= totalPages)
        {
            currentPage = newPage;
            UpdatePagedOrders();
        }
    }

    private void GoToDetail(long idOrder)
    {
        selectedOrder = allOrders.FirstOrDefault(o => o.IdOrder == idOrder);
    }
    
    private void CloseDetail()
    {
        selectedOrder = null;
    }
}
