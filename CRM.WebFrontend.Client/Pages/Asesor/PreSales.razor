@page "/asesor/preventas"
@rendermode InteractiveServer
@using CRM.WebFrontend.Client.Models
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Mis Pre-Ventas - Asesor</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Mis Pre-Ventas</h2>
            <p class="text-muted mb-0">Gestiona y haz seguimiento a tus pre-ventas y leads.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm" @onclick="OpenNewModal">
            <i class="bi bi-plus-lg me-2"></i> + Nueva Pre-Venta
        </button>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted fw-bold">Filtrar por Operador</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Ej. Movistar" @bind="filterOperator" @bind:event="oninput" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted fw-bold">Estado de Cobertura</label>
                    <select class="form-select form-select-sm" @bind="filterCoverage" @bind:event="onchange">
                        <option value="">Todos</option>
                        <option value="SI">Con Cobertura (SI)</option>
                        <option value="NO">Sin Cobertura (NO)</option>
                        <option value="PENDIENTE">Pendiente</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-secondary btn-sm w-100" @onclick="ApplyFilters">Buscar</button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2 text-muted">Cargando pre-ventas...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-4 py-3 text-muted fw-bold">N° Pre-Venta</th>
                                <th class="border-0 px-4 py-3 text-muted fw-bold">Cliente</th>
                                <th class="border-0 px-4 py-3 text-muted fw-bold">Teléfono</th>
                                <th class="border-0 px-4 py-3 text-muted fw-bold">Operador / Notas</th>
                                <th class="border-0 px-4 py-3 text-muted fw-bold">Cobertura</th>
                                <th class="border-0 px-4 py-3 text-muted fw-bold text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pagedPreSales != null && pagedPreSales.Any())
                            {
                                @foreach (var preSale in pagedPreSales)
                                {
                                    <tr class="cursor-pointer">
                                        <td class="px-4 py-3">
                                            <span class="text-primary fw-bold">#@preSale.IdPresale</span><br/>
                                            <small class="text-muted">@preSale.Register.ToString("dd/MM/yyyy")</small>
                                        </td>
                                        <td class="px-4 py-3 text-dark">
                                            @(string.IsNullOrWhiteSpace(preSale.FirstName) && string.IsNullOrWhiteSpace(preSale.LastName) ? "Sin nombre" : $"{preSale.FirstName} {preSale.LastName}".Trim())
                                        </td>
                                        <td class="px-4 py-3 fw-bold text-dark">
                                            @preSale.Phone
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="badge bg-light text-dark border mb-1">@preSale.Operator</span><br/>
                                            <small class="text-muted" style="max-width: 200px; display: inline-block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                @preSale.Notes
                                            </small>
                                        </td>
                                        <td class="px-4 py-3">
                                            @if (IsCovered(preSale.CoverageStatus))
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success">Con Cobertura</span>
                                            }
                                            else if (IsNoCoverage(preSale.CoverageStatus))
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger">Sin Cobertura</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary">Pendiente</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-end">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill me-1" @onclick="() => OpenCallModal(preSale.IdPresale)" title="Registrar Llamada">
                                                <i class="bi bi-telephone-fill"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning rounded-pill" @onclick="() => OpenAssignModal(preSale.IdPresale)" title="Derivar a otro Asesor">
                                                <i class="bi bi-person-lines-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        No se encontraron pre-ventas.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (totalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center p-3 border-top">
                        <span class="text-muted small">Mostrando @(((currentPage - 1) * pageSize) + 1) a @Math.Min(currentPage * pageSize, filteredPreSales.Count) de @filteredPreSales.Count</span>
                        <div class="btn-group">
                            <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage == 1)" @onclick="PreviousPage">
                                Anterior
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage == totalPages)" @onclick="NextPage">
                                Siguiente
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal: Nueva Pre-Venta -->
@if (showNewModal)
{
    <div class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Registrar Nueva Pre-Venta</h5>
                    <button type="button" class="btn-close" @onclick="CloseNewModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Teléfono</label>
                        <input type="text" class="form-control" @bind="newPreSale.Phone" placeholder="Número de teléfono" />
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small">Nombre</label>
                            <input type="text" class="form-control" @bind="newPreSale.FirstName" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small">Apellido</label>
                            <input type="text" class="form-control" @bind="newPreSale.LastName" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Operador Actual</label>
                        <input type="text" class="form-control" @bind="newPreSale.Operator" placeholder="Ej. Movistar, Orange..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Estado de Cobertura</label>
                        <select class="form-select" @bind="newPreSale.CoverageStatus">
                            <option value="PENDIENTE">Pendiente</option>
                            <option value="SI">Sí, validado</option>
                            <option value="NO">No hay cobertura</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Oferta Tentativa / Notas</label>
                        <textarea class="form-control" rows="2" @bind="newPreSale.Notes" placeholder="Interesado en fibra 1Gb..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill" @onclick="CloseNewModal" disabled="@isSaving">Cancelar</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="SaveNewPreSale" disabled="@(isSaving || isSuccessNew)">
                        @if(isSaving) { <span class="spinner-border spinner-border-sm me-2"></span><span>Guardando...</span> }
                        else if(isSuccessNew) { <i class="bi bi-check-circle-fill me-2"></i><span>¡Creado!</span> }
                        else { <span>Crear Pre-Venta</span> }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Registrar Llamada -->
@if (showCallModal)
{
    <div class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Registrar Llamada de Compañía</h5>
                    <button type="button" class="btn-close" @onclick="CloseCallModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Registra los detalles de la comunicación sostenida con el prospecto (Pre-Venta #@selectedPreSaleId).</p>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Detalles de la Llamada</label>
                        <textarea class="form-control" rows="4" @bind="callNotes" placeholder="El cliente no contestó, o pidió que lo llamen más tarde..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill" @onclick="CloseCallModal" disabled="@isSaving">Cancelar</button>
                    <button type="button" class="btn btn-success rounded-pill px-4" @onclick="SaveCall" disabled="@(isSaving || isSuccessCall)">
                        @if(isSaving) { <span class="spinner-border spinner-border-sm me-2"></span><span>Enviando...</span> }
                        else if(isSuccessCall) { <i class="bi bi-check-circle-fill me-2"></i><span>¡Registrado!</span> }
                        else { <span>Registrar</span> }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Derivar Asesor -->
@if (showAssignModal)
{
    <div class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Derivar a otro Asesor</h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Traslada la pre-venta #@selectedPreSaleId a otro agente.</p>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Nuevo Asesor</label>
                        <select class="form-select rounded-3" @bind="assignUserId">
                            <option value="0" disabled>-- Selecciona un asesor --</option>
                            @foreach (var adv in advisors)
                            {
                                <option value="@adv.Id">@adv.Name</option>
                            }
                        </select>
                        <div class="form-text">Selecciona el asesor de destino para transferir la pre-venta.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Contexto de la Derivación</label>
                        <textarea class="form-control" rows="2" @bind="assignContext" placeholder="Motivo de la transferencia..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill" @onclick="CloseAssignModal" disabled="@isSaving">Cancelar</button>
                    <button type="button" class="btn btn-warning rounded-pill px-4 text-dark" @onclick="SaveAssign" disabled="@(isSaving || isSuccessAssign)">
                        @if(isSaving) { <span class="spinner-border spinner-border-sm me-2"></span><span>Transfiriendo...</span> }
                        else if(isSuccessAssign) { <i class="bi bi-check-circle-fill me-2"></i><span>¡Transferido!</span> }
                        else { <span>Transferir</span> }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .cursor-pointer { cursor: pointer; }
    .cursor-pointer:hover { background-color: #f8f9fa !important; }
</style>

@code {
    private List<PreSaleDto> allPreSales = new();
    private List<PreSaleDto> filteredPreSales = new();
    private List<PreSaleDto> pagedPreSales = new();
    
    private bool isLoading = true;
    private bool isSaving = false;
    private int currentUserId = 0;
    
    // Paginación
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((double)filteredPreSales.Count / pageSize);

    // Filtros
    private string filterOperator = "";
    private string filterCoverage = "";

    // Modales y Estados
    private bool showNewModal = false;
    private bool showCallModal = false;
    private bool showAssignModal = false;
    
    private bool isSuccessNew = false;
    private bool isSuccessCall = false;
    private bool isSuccessAssign = false;
    
    private PreSaleDto newPreSale = new() { CoverageStatus = "PENDIENTE" };
    private long selectedPreSaleId = 0;
    private string callNotes = "";
    private int assignUserId = 0;
    private string assignContext = "";

    private List<AdvisorLookupDto> advisors = new();

    public class AdvisorLookupDto 
    { 
        public int Id { get; set; } 
        public string Name { get; set; } = string.Empty; 
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var idUserClaim = user.FindFirst(c => c.Type == "id_user" || c.Type == System.Security.Claims.ClaimTypes.NameIdentifier);
            if (idUserClaim != null && int.TryParse(idUserClaim.Value, out int uid))
            {
                currentUserId = uid;
            }
        }
        await LoadAdvisorsAsync();
        await LoadPreSalesAsync();
    }

    private async Task LoadAdvisorsAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var result = await client.GetFromJsonAsync<List<AdvisorLookupDto>>("/api/campaigns/advisors");
            if (result != null)
            {
                advisors = result;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading advisors: {ex.Message}");
        }
    }

    private async Task LoadPreSalesAsync()
    {
        isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var result = await client.GetFromJsonAsync<List<PreSaleDto>>($"/api/presales?userId={currentUserId}");
            
            if (result != null)
            {
                allPreSales = result.OrderByDescending(p => p.Register).ToList();
                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        var temp = allPreSales.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(filterOperator))
            temp = temp.Where(p => p.Operator != null && p.Operator.Contains(filterOperator, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(filterCoverage))
        {
            if (filterCoverage == "SI")
            {
                temp = temp.Where(p => IsCovered(p.CoverageStatus));
            }
            else if (filterCoverage == "NO")
            {
                temp = temp.Where(p => IsNoCoverage(p.CoverageStatus));
            }
            else if (filterCoverage == "PENDIENTE")
            {
                temp = temp.Where(p => !IsCovered(p.CoverageStatus) && !IsNoCoverage(p.CoverageStatus));
            }
        }

        filteredPreSales = temp.ToList();
        currentPage = 1;
        UpdatePagedPreSales();
    }

    private void UpdatePagedPreSales()
    {
        pagedPreSales = filteredPreSales
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void PreviousPage()
    {
        if (currentPage > 1) { currentPage--; UpdatePagedPreSales(); }
    }

    private void NextPage()
    {
        if (currentPage < totalPages) { currentPage++; UpdatePagedPreSales(); }
    }

    // --- Lógica de Nueva Pre-Venta ---
    private void OpenNewModal()
    {
        newPreSale = new() { 
            CoverageStatus = "PENDIENTE", 
            CurrentUserId = currentUserId, 
            OwnerUserId = currentUserId,
            IdCmpg = 1, // Por defecto campaña 1
            IdStatus = 1 // Por defecto estado 1 (ej. Pendiente/Nuevo)
        };
        showNewModal = true;
    }
    private void CloseNewModal() => showNewModal = false;
    
    private async Task SaveNewPreSale()
    {
        isSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var response = await client.PostAsJsonAsync("/api/presales", newPreSale);
            if (response.IsSuccessStatusCode)
            {
                isSuccessNew = true;
                StateHasChanged();
                await Task.Delay(1500);
                Snackbar.Add("Pre-Venta registrada correctamente.", Severity.Success);
                showNewModal = false;
                isSuccessNew = false;
                await LoadPreSalesAsync(); // Recargar datos
            }
            else
            {
                Snackbar.Add("Error al registrar pre-venta.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de red: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    // --- Lógica de Registrar Llamada ---
    private void OpenCallModal(long id)
    {
        selectedPreSaleId = id;
        callNotes = "";
        showCallModal = true;
    }
    private void CloseCallModal() => showCallModal = false;

    private async Task SaveCall()
    {
        isSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var payload = new { CallLog = callNotes };
            var response = await client.PostAsJsonAsync($"/api/presales/{selectedPreSaleId}/calls", payload);
            if (response.IsSuccessStatusCode)
            {
                isSuccessCall = true;
                StateHasChanged();
                await Task.Delay(1500);
                Snackbar.Add("Llamada registrada correctamente.", Severity.Success);
                showCallModal = false;
                isSuccessCall = false;
            }
            else
            {
                Snackbar.Add("Error al registrar llamada.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de red: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    // --- Lógica de Derivar Asesor ---
    private void OpenAssignModal(long id)
    {
        selectedPreSaleId = id;
        assignUserId = 0;
        assignContext = "";
        showAssignModal = true;
    }
    private void CloseAssignModal() => showAssignModal = false;

    private async Task SaveAssign()
    {
        if(assignUserId <= 0)
        {
            Snackbar.Add("Debe ingresar un ID de Asesor válido.", Severity.Warning);
            return;
        }

        isSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var payload = new { ToUserId = assignUserId, Context = assignContext };
            var response = await client.PostAsJsonAsync($"/api/presales/{selectedPreSaleId}/assign", payload);
            if (response.IsSuccessStatusCode)
            {
                isSuccessAssign = true;
                StateHasChanged();
                await Task.Delay(1500);
                Snackbar.Add("Pre-Venta derivada con éxito.", Severity.Success);
                showAssignModal = false;
                isSuccessAssign = false;
                await LoadPreSalesAsync(); // Recargar datos porque ya no es nuestra pre-venta
            }
            else
            {
                Snackbar.Add("Error al derivar pre-venta.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de red: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private bool IsCovered(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        var s = status.Trim();
        return string.Equals(s, "SI", StringComparison.OrdinalIgnoreCase) || 
               string.Equals(s, "COVERED", StringComparison.OrdinalIgnoreCase) || 
               string.Equals(s, "AVAILABLE", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsNoCoverage(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return false;
        var s = status.Trim();
        return string.Equals(s, "NO", StringComparison.OrdinalIgnoreCase) || 
               string.Equals(s, "NO_COVERAGE", StringComparison.OrdinalIgnoreCase);
    }
}
