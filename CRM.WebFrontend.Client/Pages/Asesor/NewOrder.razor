@page "/asesor/orders/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@using CRM.WebFrontend.Client.Models
@using System.Text.RegularExpressions
@using MudBlazor
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "ASESOR")]

<PageTitle>Nueva Orden - Asesor</PageTitle>

<div class="container-fluid max-w-4xl mx-auto py-4">
    <div class="d-flex align-items-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Class="me-3 text-primary" Style="font-size: 2rem;" />
        <h2 class="fw-bold mb-0">Generar Nueva Orden</h2>
    </div>

    @if (isLoadingInitialData)
    {
        <div class="d-flex justify-content-center p-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <!-- Paso 1: Selección de Campaña y Pipeline -->
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold text-dark mb-4">1. Selección de Cliente, Campaña y Etapa</h5>
                
                <div class="row g-4">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Cliente (Lead)</label>
                        <select class="form-select form-select-lg rounded-3" @bind="selectedLeadId">
                            <option value="0" disabled selected="@(selectedLeadId == 0)">-- Selecciona un cliente --</option>
                            @foreach (var l in leads)
                            {
                                <option value="@l.IdLead">@l.FirstName @l.LastName</option>
                            }
                        </select>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Campaña</label>
                        <select class="form-select form-select-lg rounded-3" value="@selectedCampaignId" @onchange="OnCampaignSelected">
                            <option value="0" disabled>-- Selecciona una campaña --</option>
                            @foreach (var cmpg in campaigns)
                            {
                                <option value="@cmpg.Id">@cmpg.Name</option>
                            }
                        </select>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Etapa (Pipeline)</label>
                        <select class="form-select form-select-lg rounded-3" value="@selectedStatusId" @onchange="OnStatusSelected" disabled="@(selectedCampaignId == 0)">
                            <option value="0" disabled>-- Selecciona una etapa --</option>
                            @foreach (var st in statuses)
                            {
                                <option value="@st.Id">@st.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Paso 2: Formulario Dinámico -->
        @if (isLoadingSchema)
        {
            <div class="d-flex justify-content-center p-5">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            </div>
        }
        else if (formSchema != null && formSchema.Fields.Any())
        {
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4">2. Datos de la Orden</h5>
                    
                    <EditForm Model="formSchema" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="row g-4">
                            @foreach (var field in formSchema.Fields)
                            {
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">
                                        @field.Label
                                        @if (field.IsRequired)
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </label>
                                    
                                    @if (!string.IsNullOrEmpty(field.HelpText))
                                    {
                                        <div class="form-text text-muted mb-2"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1"/>@field.HelpText</div>
                                    }

                                    @if (field.FieldType == "select")
                                    {
                                        <select class="form-select rounded-3" @bind="field.Value" required="@field.IsRequired">
                                            <option value="">-- Selecciona --</option>
                                            @if (!string.IsNullOrEmpty(field.Options))
                                            {
                                                try {
                                                    var opts = System.Text.Json.JsonSerializer.Deserialize<List<string>>(field.Options);
                                                    if(opts != null) {
                                                        foreach(var opt in opts) {
                                                            <option value="@opt">@opt</option>
                                                        }
                                                    }
                                                } catch {
                                                    <!-- Si no es JSON array, parseamos por comas como fallback -->
                                                    @foreach(var opt in field.Options.Split(',')) {
                                                        <option value="@opt.Trim()">@opt.Trim()</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    }
                                    else if (field.FieldType == "date")
                                    {
                                        <input type="date" class="form-control rounded-3" value="@field.Value" @onchange="@(e => field.Value = e.Value?.ToString() ?? string.Empty)" required="@field.IsRequired" />
                                    }
                                    else if (field.FieldType == "file")
                                    {
                                        <InputFile class="form-control rounded-3" OnChange="@(e => OnFileChange(field, e))" required="@field.IsRequired" />
                                    }
                                    else
                                    {
                                        <input type="text" 
                                               class="form-control rounded-3" 
                                               placeholder="@field.Placeholder"
                                               @bind="field.Value" 
                                               required="@field.IsRequired" 
                                               pattern="@GetValidationPattern(field)"
                                               title="@GetValidationTitle(field)" />
                                    }
                                    
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-light rounded-pill px-4 me-2" @onclick='() => Navigation.NavigateTo("/asesor")' disabled="@isSaving">
                                Cancelar
                            </button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 d-flex align-items-center" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <MudProgressCircular Class="me-2" Size="Size.Small" Color="Color.Surface" Indeterminate="true" />
                                    <span>Guardando...</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Save" Class="me-2" Size="Size.Small" />
                                    <span>Guardar Orden</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
        else if (selectedStatusId > 0 && !isLoadingSchema)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="rounded-4">
                No hay un formulario configurado para esta campaña y etapa.
            </MudAlert>
        }
    }
</div>

@code {
    private bool isLoadingInitialData = true;
    private bool isLoadingSchema = false;
    private bool isSaving = false;
    private int currentUserId = 0;

    public class LeadSimpleDto
    {
        public long IdLead { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
    }

    private List<CampaignDto> campaigns = new();
    private List<OrderStatusDto> statuses = new();
    private List<LeadSimpleDto> leads = new();
    
    private int selectedCampaignId = 0;
    private int selectedStatusId = 0;
    private long selectedLeadId = 0;

    private FormSchemaDto? formSchema = null;

    protected override async Task OnInitializedAsync()
    {
        // Extraer userId del JWT
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdStr = user.FindFirst("id_user")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out int uid))
            {
                currentUserId = uid;
            }
        }

        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var result = await client.GetFromJsonAsync<List<CampaignDto>>("/api/campaigns");
            if (result != null)
            {
                campaigns = result;
            }
            
            var leadsResult = await client.GetFromJsonAsync<List<LeadSimpleDto>>("/api/leads");
            if (leadsResult != null)
            {
                leads = leadsResult;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar campañas: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoadingInitialData = false;
        }
    }

    private async Task OnCampaignSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedCampaignId = id;
            selectedStatusId = 0;
            formSchema = null;
            if (selectedCampaignId > 0)
            {
                try
                {
                    var client = HttpClientFactory.CreateClient("BackendApi");
                    var result = await client.GetFromJsonAsync<List<OrderStatusDto>>($"/api/campaigns/{selectedCampaignId}/statuses");
                    if (result != null)
                    {
                        statuses = result;
                    }
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error al cargar estados: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private async Task OnStatusSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedStatusId = id;
            if (selectedCampaignId > 0 && selectedStatusId > 0)
            {
                isLoadingSchema = true;
                formSchema = null;
                try
                {
                    var client = HttpClientFactory.CreateClient("BackendApi");
                    
                    // 1. Get templates for this campaign and stage
                    var templatesResponse = await client.GetAsync($"/api/forms/campaign/{selectedCampaignId}/stage/{selectedStatusId}");
                    
                    if (templatesResponse.IsSuccessStatusCode)
                    {
                        var templates = await templatesResponse.Content.ReadFromJsonAsync<List<FormTemplateDto>>();
                        var firstTemplate = templates?.FirstOrDefault();
                        
                        if (firstTemplate != null)
                        {
                            // 2. Get fields for the template
                            var fieldsResponse = await client.GetAsync($"/api/forms/{firstTemplate.IdForm}/fields");
                            if (fieldsResponse.IsSuccessStatusCode)
                            {
                                var fields = await fieldsResponse.Content.ReadFromJsonAsync<List<FormFieldDto>>();
                                if (fields != null)
                                {
                                    formSchema = new FormSchemaDto 
                                    {
                                        IdForm = firstTemplate.IdForm,
                                        Name = firstTemplate.Name,
                                        Fields = fields
                                    };
                                }
                            }
                        }
                    }
                    
                    if (formSchema == null)
                    {
                        // No schema found or error occurred but handled gracefully
                    }
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error de red: {ex.Message}", Severity.Error);
                }
                finally
                {
                    isLoadingSchema = false;
                }
            }
        }
    }

    private void OnFileChange(FormFieldDto field, InputFileChangeEventArgs e)
    {
        field.Value = e.File.Name; // Mock file name saving for now
    }

    private string? GetValidationPattern(FormFieldDto field)
    {
        if (!string.IsNullOrEmpty(field.ValidationRegex))
        {
            return field.ValidationRegex;
        }

        // Predefined validations via HTML5 pattern matching for client-side
        return field.ValidationType switch
        {
            "DNI_ES" => "^[0-9]{8}[TRWAGMYFPDXBNJZSQVHLCKE]$",
            "NIE_ES" => "^[XYZ][0-9]{7}[TRWAGMYFPDXBNJZSQVHLCKE]$",
            "PHONE_ES" => "^[6789][0-9]{8}$",
            "CUPS_ENERGY" => "^ES[0-9]{20}[A-Z]{2}$",
            _ => null
        };
    }

    private string? GetValidationTitle(FormFieldDto field)
    {
        return field.ValidationType switch
        {
            "DNI_ES" => "Debe ser un DNI válido (8 números y 1 letra mayúscula)",
            "NIE_ES" => "Debe ser un NIE válido (empieza con X, Y o Z)",
            "PHONE_ES" => "Debe ser un teléfono español de 9 dígitos",
            "CUPS_ENERGY" => "Debe ser un código CUPS válido (empieza por ES)",
            _ => field.IsRequired ? "Este campo es requerido" : null
        };
    }

    private class OrderDataSubmitDto
    {
        public long IdFld { get; set; }
        public string? ValueText { get; set; }
    }

    private async Task HandleSubmit()
    {
        if (formSchema == null) return;
        
        if (selectedLeadId == 0)
        {
            Snackbar.Add("Debes seleccionar un cliente (Lead) para la orden.", Severity.Warning);
            return;
        }

        isSaving = true;
        try
        {
            var createOrderDto = new
            {
                idLead = selectedLeadId,
                idCmpg = selectedCampaignId,
                idUser = currentUserId, // Extraído del JWT del usuario autenticado
                idStatus = selectedStatusId,
                status = "PENDING_VALIDATION"
            };

            var client = HttpClientFactory.CreateClient("BackendApi");
            
            // 1. Create the base order
            var response = await client.PostAsJsonAsync("/api/orders", createOrderDto);

            if (response.IsSuccessStatusCode)
            {
                long newOrderId = 0;
                var responseString = await response.Content.ReadAsStringAsync();
                
                try
                {
                    var jsonDoc = System.Text.Json.JsonDocument.Parse(responseString);
                    if (jsonDoc.RootElement.TryGetProperty("idOrder", out var idProp) && idProp.TryGetInt64(out long parsedId))
                    {
                        newOrderId = parsedId;
                    }
                }
                catch { /* Ignore parsing errors */ }

                if (newOrderId > 0)
                {
                    // 2. Save the dynamic form data
                    var fieldsData = formSchema.Fields.Select(f => new OrderDataSubmitDto
                    {
                        IdFld = f.IdFld,
                        ValueText = f.Value
                    }).ToList();

                    var formDataResponse = await client.PostAsJsonAsync($"/api/forms/order/{newOrderId}/template/{formSchema.IdForm}", fieldsData);
                    
                    if (!formDataResponse.IsSuccessStatusCode)
                    {
                        Snackbar.Add("Orden creada, pero falló al guardar los datos del formulario.", Severity.Warning);
                    }
                }
                
                Snackbar.Add("Orden creada exitosamente", Severity.Success);
                Navigation.NavigateTo("/asesor/orders");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al crear la orden: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }
}
