@page "/supervisor/bulk-transfer"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@using System.Text.Json
@using MudBlazor
@attribute [Authorize(Roles = "SUPERVISOR")]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>Envío Masivo al BAC - Supervisor</PageTitle>

<div class="container-fluid py-4">
    @* ───── Header ───── *@
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary mb-1">Envío Masivo al BAC</h2>
            <p class="text-muted mb-0">Selecciona las ventas en Revisión Supervisor que deseas transferir al Backoffice.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <button class="btn btn-outline-secondary rounded-pill px-4" @onclick='() => NavManager.NavigateTo("/supervisor/dashboard")'>
                Volver al Kanban
            </button>
        </div>
    </div>

    @* ───── Panel de Acciones ───── *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-bold text-muted small">Asignar a Analista BAC</label>
                    <select class="form-select rounded-3" @bind="selectedBacUserId">
                        <option value="0">-- Seleccione un usuario de Backoffice --</option>
                        @foreach (var bac in backofficeUsers)
                        {
                            <option value="@bac.Id">@bac.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Comentario de Transferencia (Opcional)</label>
                    <input type="text" class="form-control rounded-3" @bind="transferComment" placeholder="Ej: Revisado y conforme..." />
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-primary rounded-pill px-4 w-100" 
                            disabled="@(SelectedCount == 0 || selectedBacUserId == 0)"
                            @onclick="ShowConfirmation">
                        Transferir (@SelectedCount)
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ───── Tabla de Órdenes ───── *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 py-3" style="width: 50px;">
                                <input class="form-check-input" type="checkbox" 
                                       checked="@IsAllSelected" 
                                       @onchange="ToggleAll" />
                            </th>
                            <th class="py-3">ID</th>
                            <th class="py-3">Fecha</th>
                            <th class="py-3">Campaña</th>
                            <th class="py-3">Cliente</th>
                            <th class="py-3">Asesor</th>
                            <th class="py-3">Días Transcurridos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    Cargando ventas...
                                </td>
                            </tr>
                        }
                        else if (!orders.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    No hay ventas en estado de Revisión Supervisor para transferir.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <input class="form-check-input" type="checkbox" 
                                               checked="@order.IsSelected" 
                                               @onchange="@((ChangeEventArgs e) => ToggleOrder(order, (bool)e.Value!))" />
                                    </td>
                                    <td class="py-3 fw-bold text-primary">#@order.IdOrder</td>
                                    <td class="py-3">@order.SalesDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="py-3">
                                        <span class="badge bg-light text-dark border">@order.CampaignName</span>
                                    </td>
                                    <td class="py-3 fw-medium">@order.ClientName</td>
                                    <td class="py-3">@order.AdvisorName</td>
                                    <td class="py-3">
                                        <span class="badge @(order.DaysElapsed > 3 ? "bg-danger" : "bg-warning text-dark") rounded-pill">
                                            @order.DaysElapsed días
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* ───── Modal de Confirmación ───── *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-primary">Confirmar Transferencia</h5>
                    <button type="button" class="btn-close" @onclick="CloseConfirmation"></button>
                </div>
                <div class="modal-body py-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-arrow-right-circle text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <p class="fs-5 mb-1">Se transferirán <strong>@SelectedCount</strong> órdenes al BAC.</p>
                    <p class="text-muted small">
                        Analista destino: <strong>@(backofficeUsers.FirstOrDefault(b => b.Id == selectedBacUserId)?.Name)</strong>
                    </p>
                </div>
                <div class="modal-footer border-top-0 pt-0 justify-content-center">
                    <button type="button" class="btn btn-light rounded-pill px-4" @onclick="CloseConfirmation" disabled="@isTransferring">Cancelar</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" @onclick="ExecuteTransfer" disabled="@isTransferring">
                        @if (isTransferring)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Procesando...</span>
                        }
                        else
                        {
                            <span>Confirmar Envío</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class CampaignLookup { public int Id { get; set; } public string Name { get; set; } = ""; }
    public class StatusDto { public long Id { get; set; } public string Name { get; set; } = ""; public string? Color { get; set; } }
    public class UserDto { public long Id { get; set; } public string Name { get; set; } = ""; }
    
    public class SelectableOrder
    {
        public long IdOrder { get; set; }
        public long IdLead { get; set; }
        public long IdCmpg { get; set; }
        public long IdUser { get; set; }
        public long? IdStatus { get; set; }
        public DateTime SalesDate { get; set; }
        public string ClientName { get; set; } = "";
        public string CampaignName { get; set; } = "";
        public string StatusName { get; set; } = "";
        public string AdvisorName { get; set; } = "";
        public int DaysElapsed => (DateTime.UtcNow - SalesDate).Days;
        public bool IsSelected { get; set; }
    }

    private bool isLoading = true;
    private bool isTransferring = false;
    private bool showModal = false;
    
    private List<SelectableOrder> orders = new();
    private List<UserDto> backofficeUsers = new();
    private long selectedBacUserId = 0;
    private string transferComment = "";

    private int SelectedCount => orders.Count(o => o.IsSelected);
    private bool IsAllSelected => orders.Any() && orders.All(o => o.IsSelected);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            var client = HttpClientFactory.CreateClient("BackendApi");

            // 1. Cargar usuarios BAC
            try
            {
                var bacResult = await client.GetFromJsonAsync<List<UserDto>>("/api/campaigns/advisors?role=BACKOFFICE");
                if (bacResult != null) backofficeUsers = bacResult;
            }
            catch { /* ignora fallos menores para permitir visualizacion */ }

            // 2. Cargar Asesores (para nombres)
            List<UserDto> advisors = new();
            try
            {
                var advResult = await client.GetFromJsonAsync<List<UserDto>>("/api/campaigns/advisors?role=ASESOR");
                if (advResult != null) advisors = advResult;
            }
            catch { }

            // 3. Cargar Campañas
            List<CampaignLookup> campaigns = new();
            var cmpgResult = await client.GetFromJsonAsync<List<CampaignLookup>>("/api/campaigns");
            if (cmpgResult != null) campaigns = cmpgResult;

            // 4. Cargar Estados (para saber cuál es Revisión Supervisor)
            List<StatusDto> statuses = new();
            var statResult = await client.GetFromJsonAsync<List<StatusDto>>("/api/campaigns/1/statuses");
            if (statResult != null) statuses = statResult;

            // 5. Cargar órdenes del equipo
            var ordersResult = await client.GetFromJsonAsync<List<SelectableOrder>>("/api/supervisor/orders");
            
            if (ordersResult != null)
            {
                // Filtrar por estado "REVISION_SUPERVISOR" o similar (ID 2 típicamente o por nombre)
                var revStatus = statuses.FirstOrDefault(s => s.Name.Contains("SUPERVISOR", StringComparison.OrdinalIgnoreCase));
                long targetStatusId = revStatus?.Id ?? 2;

                var filtered = ordersResult.Where(o => o.IdStatus == targetStatusId).ToList();

                // Enriquecer con nombres
                foreach (var o in filtered)
                {
                    o.CampaignName = campaigns.FirstOrDefault(c => c.Id == o.IdCmpg)?.Name ?? "Desconocida";
                    o.StatusName = revStatus?.Name ?? "Revisión Supervisor";
                    
                    var adv = advisors.FirstOrDefault(a => a.Id == o.IdUser);
                    o.AdvisorName = adv != null && !string.IsNullOrWhiteSpace(adv.Name) ? adv.Name : $"Asesor {o.IdUser}";
                    o.ClientName = !string.IsNullOrEmpty(o.ClientName) ? o.ClientName : "";
                }

                // Cargar nombres de clientes
                var uniqueLeadIds = filtered.Where(o => string.IsNullOrEmpty(o.ClientName)).Select(o => o.IdLead).Distinct().ToList();
                foreach (var leadId in uniqueLeadIds)
                {
                    try
                    {
                        var leadData = await client.GetFromJsonAsync<JsonElement>($"/api/leads/{leadId}");
                        string fName = leadData.GetProperty("firstName").GetString() ?? "";
                        string lName = leadData.GetProperty("lastName").GetString() ?? "";
                        string realName = $"{fName} {lName}".Trim();
                        
                        if (!string.IsNullOrEmpty(realName))
                        {
                            foreach (var o in filtered.Where(x => x.IdLead == leadId)) o.ClientName = realName;
                        }
                    }
                    catch 
                    {
                        // Si falla (por ser data mock 404), remover de la lista tal como se acordó en el kanban
                        filtered.RemoveAll(x => x.IdLead == leadId);
                    }
                }

                orders = filtered;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar datos: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAll(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        foreach (var order in orders)
        {
            order.IsSelected = isChecked;
        }
    }

    private void ToggleOrder(SelectableOrder order, bool isChecked)
    {
        order.IsSelected = isChecked;
    }

    private void ShowConfirmation()
    {
        if (SelectedCount > 0 && selectedBacUserId > 0)
        {
            showModal = true;
        }
    }

    private void CloseConfirmation()
    {
        if (!isTransferring)
        {
            showModal = false;
        }
    }

    private async Task ExecuteTransfer()
    {
        var selectedOrderIds = orders.Where(o => o.IsSelected).Select(o => o.IdOrder).ToArray();
        
        if (selectedOrderIds.Length == 0 || selectedBacUserId == 0) return;

        isTransferring = true;

        try
        {
            var client = HttpClientFactory.CreateClient("BackendApi");
            var payload = new
            {
                OrderIds = selectedOrderIds,
                BackofficeUserId = selectedBacUserId,
                Comment = string.IsNullOrWhiteSpace(transferComment) ? "Enviado masivamente al BAC desde Dashboard" : transferComment
            };

            var response = await client.PostAsJsonAsync("/api/supervisor/bulk-transfer", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{selectedOrderIds.Length} órdenes transferidas exitosamente.", Severity.Success);
                showModal = false;
                
                // Redirigir al Kanban como solicita el requerimiento: "Actualiza kanban automáticamente"
                NavManager.NavigateTo("/supervisor/dashboard");
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<JsonElement>();
                string msg = error.TryGetProperty("message", out var m) ? m.GetString() ?? "Error desconocido" : "Error desconocido";
                Snackbar.Add($"No se pudieron transferir las órdenes: {msg}", Severity.Error);
                showModal = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error de conexión: {ex.Message}", Severity.Error);
            showModal = false;
        }
        finally
        {
            isTransferring = false;
        }
    }
}
