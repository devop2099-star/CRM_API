@page "/asesor"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "ASESOR")]

<PageTitle>Dashboard Asesor</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">Panel de Control - Asesor</h2>
            <p class="text-muted">Resumen de tu rendimiento diario y oportunidades.</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Card Mis Pre-Ventas -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-primary mb-3">Mis pre-ventas</h5>
                    <h2 class="display-4 fw-bold">12</h2>
                    <p class="card-text text-muted">Tickets en seguimiento</p>
                    <button class="btn btn-outline-primary w-100 mt-3 rounded-pill fw-bold">Gestionar</button>
                </div>
            </div>
        </div>

        <!-- Card Mis Ventas -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-success mb-3">Mis ventas</h5>
                    <h2 class="display-4 fw-bold">4</h2>
                    <p class="card-text text-muted">Cerradas hoy</p>
                    <button class="btn btn-outline-success w-100 mt-3 rounded-pill fw-bold">Ver Detalle</button>
                </div>
            </div>
        </div>

        <!-- Card Alertas -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4 border-start border-4 border-danger">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-danger mb-3">Alertas</h5>
                    <h2 class="display-4 fw-bold">2</h2>
                    <p class="card-text text-muted">Requieren atención urgente</p>
                    <button class="btn btn-outline-danger w-100 mt-3 rounded-pill fw-bold">Revisar</button>
                </div>
            </div>
        </div>
    </div>
</div>
