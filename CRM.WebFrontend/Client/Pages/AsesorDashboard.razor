@page "/asesor"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "ASESOR")]

<PageTitle>Dashboard Asesor</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Color="Color.Secondary" GutterBottom="true">Panel de Control: Asesor</MudText>
    
    <AuthorizeView>
        <Authorized>
            <MudAlert Severity="Severity.Info">Bienvenido, @context.User.Identity?.Name. ¡Tu rol es ASESOR y estás autenticado mediante Cookies HttpOnly!</MudAlert>
        </Authorized>
    </AuthorizeView>
</MudContainer>
