@page "/supervisor/equipo"
@page "/backoffice/equipo"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SUPERVISOR,BACKOFFICE")]
@inject HttpClient Http

<PageTitle>Rendimiento de Equipo - NYX CRM</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-12">
            <h2 class="fw-bold text-primary mb-1">Rendimiento de Equipo</h2>
            <p class="text-muted mb-0">Visualiza las métricas y ventas globales de todos los asesores.</p>
        </div>
    </div>

    <!-- Indicadores Globales -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="text-muted mb-3">Ventas Totales del Mes</h5>
                    <h2 class="display-5 fw-bold text-success mb-0">142</h2>
                    <small class="text-success fw-bold">↑ 12% vs Mes Anterior</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="text-muted mb-3">Tasa de Conversión</h5>
                    <h2 class="display-5 fw-bold text-primary mb-0">18.5%</h2>
                    <small class="text-primary fw-bold">Estable</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
                <div class="card-body p-4 text-center">
                    <h5 class="text-white-50 mb-3">Asesores Activos</h5>
                    <h2 class="display-5 fw-bold mb-0">24 / 30</h2>
                    <small class="text-white">En línea ahora mismo</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Buscar Asesor</label>
                    <input type="text" class="form-control rounded-3" placeholder="Nombre del asesor..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small">Mes</label>
                    <input type="month" class="form-control rounded-3" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary rounded-pill px-4 w-100">Actualizar Datos</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 py-3">Asesor</th>
                            <th class="py-3">Campañas</th>
                            <th class="py-3 text-center">Contactos Totales</th>
                            <th class="py-3 text-center">Ventas Cerradas</th>
                            <th class="py-3 text-center">Conversión</th>
                            <th class="pe-4 py-3 text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    Cargando rendimiento...
                                </td>
                            </tr>
                        }
                        else
                        {
                            <!-- Mock Data Row 1 -->
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">JS</div>
                                        <span class="fw-bold">Juan Sayago</span>
                                    </div>
                                </td>
                                <td>Portabilidad Claro</td>
                                <td class="text-center fw-bold">145</td>
                                <td class="text-center fw-bold text-success">28</td>
                                <td class="text-center">
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: 19%;" aria-valuenow="19" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small class="text-muted mt-1 d-block">19.3%</small>
                                </td>
                                <td class="pe-4 text-center">
                                    <span class="badge bg-success rounded-pill px-3">Activo</span>
                                </td>
                            </tr>
                            <!-- Mock Data Row 2 -->
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">MF</div>
                                        <span class="fw-bold">María Farfán</span>
                                    </div>
                                </td>
                                <td>Renovaciones</td>
                                <td class="text-center fw-bold">98</td>
                                <td class="text-center fw-bold text-success">15</td>
                                <td class="text-center">
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-warning" role="progressbar" style="width: 15%;" aria-valuenow="15" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small class="text-muted mt-1 d-block">15.3%</small>
                                </td>
                                <td class="pe-4 text-center">
                                    <span class="badge bg-warning text-dark rounded-pill px-3">En pausa</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await Task.Delay(800); // Simulando carga mientras se integra el endpoint
        // Aquí iría la carga real desde el API para métricas globales
        isLoading = false;
    }
}
