@page "/"
@inject NavigationManager Navigation

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var authState = await AuthStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            if (user.IsInRole("SUPERVISOR"))
            {
                Navigation.NavigateTo("/supervisor");
            }
            else if (user.IsInRole("BACKOFFICE"))
            {
                Navigation.NavigateTo("/backoffice/dashboard");
            }
            else if (user.IsInRole("ADMIN") || user.IsInRole("ADMIN_CRM") || user.IsInRole("COORDINADOR"))
            {
                Navigation.NavigateTo("/admin");
            }
            else
            {
                Navigation.NavigateTo("/asesor");
            }
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
    }
}
