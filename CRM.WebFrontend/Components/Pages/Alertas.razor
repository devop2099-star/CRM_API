@page "/supervisor/alertas"
@page "/backoffice/alertas"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SUPERVISOR,BACKOFFICE")]

<PageTitle>Alertas Activas - NYX CRM</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-12">
            <h2 class="fw-bold text-danger mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i> Alertas Activas</h2>
            <p class="text-muted mb-0">Gestión de seguimientos pendientes y quiebres de SLA.</p>
        </div>
    </div>

    <!-- Indicadores de Alertas -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-danger text-white">
                <div class="card-body p-4 text-center">
                    <h5 class="text-white-50 mb-3">SLA Excedido (Crítico)</h5>
                    <h2 class="display-5 fw-bold mb-0">3</h2>
                    <small class="text-white mt-2 d-block">Requiere atención inmediata</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning text-dark">
                <div class="card-body p-4 text-center">
                    <h5 class="text-muted mb-3">Seguimientos Pendientes</h5>
                    <h2 class="display-5 fw-bold mb-0">12</h2>
                    <small class="text-muted mt-2 d-block">Próximos a vencer hoy</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Alertas -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-2">
            <h5 class="fw-bold mb-0">Detalle de Alertas</h5>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush rounded-bottom-4">
                @if (isLoading)
                {
                    <div class="text-center py-5 text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                        Cargando alertas...
                    </div>
                }
                else
                {
                    <!-- Alerta 1 -->
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-3 mt-1" style="width: 45px; height: 45px;">
                                <i class="bi bi-clock-history fs-5"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">SLA Vencido - Promesa de Venta</h6>
                                <p class="text-muted mb-1 small">Cliente: <span class="fw-bold text-dark">Carlos Mendoza</span> (987654321)</p>
                                <p class="text-muted mb-0 small">Asesor asignado: <span class="fw-bold text-dark">Juan Sayago</span> - Retraso de 2 horas.</p>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-outline-danger rounded-pill px-4 btn-sm">Ver Detalles</button>
                        </div>
                    </div>

                    <!-- Alerta 2 -->
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-4">
                        <div class="d-flex align-items-start">
                            <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center me-3 mt-1" style="width: 45px; height: 45px;">
                                <i class="bi bi-telephone-outbound fs-5"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Llamada de Seguimiento Pendiente</h6>
                                <p class="text-muted mb-1 small">Cliente: <span class="fw-bold text-dark">Empresa SAC</span> (912345678)</p>
                                <p class="text-muted mb-0 small">Asesor asignado: <span class="fw-bold text-dark">María Farfán</span> - Vence en 30 minutos.</p>
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-outline-warning text-dark rounded-pill px-4 btn-sm fw-bold border-2">Ver Detalles</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        await Task.Delay(600); // Simulación de carga del backend
        isLoading = false;
    }
}
