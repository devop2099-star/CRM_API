@page "/login"
@rendermode InteractiveServer
@layout CRM.WebFrontend.Client.Layout.EmptyLayout
@inject NavigationManager Navigation

<PageTitle>Login - NYX CRM</PageTitle>

<style>
    body {
        background-color: #f7f9fc;
        margin: 0;
        font-family: 'Inter', 'Roboto', sans-serif;
        overflow: hidden;
        position: relative;
    }

    /* Bolitas animadas moviéndose por toda la pantalla */
    .bg-blob-1 {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(166,192,254,0.4) 0%, rgba(166,192,254,0) 70%);
        border-radius: 50%;
        top: 0;
        left: 0;
        animation: moveAround1 25s linear infinite;
        z-index: -1;
    }

    .bg-blob-2 {
        position: absolute;
        width: 650px;
        height: 650px;
        background: radial-gradient(circle, rgba(132,250,176,0.3) 0%, rgba(132,250,176,0) 70%);
        border-radius: 50%;
        bottom: 0;
        right: 0;
        animation: moveAround2 30s linear infinite;
        z-index: -1;
    }

    @@keyframes moveAround1 {
        0% { transform: translate(-10vw, -10vh) scale(1); }
        25% { transform: translate(70vw, 20vh) scale(1.2); }
        50% { transform: translate(30vw, 80vh) scale(0.9); }
        75% { transform: translate(-20vw, 50vh) scale(1.1); }
        100% { transform: translate(-10vw, -10vh) scale(1); }
    }
    
    @@keyframes moveAround2 {
        0% { transform: translate(10vw, 10vh) scale(1); }
        25% { transform: translate(-60vw, -30vh) scale(1.1); }
        50% { transform: translate(-30vw, -80vh) scale(1.3); }
        75% { transform: translate(20vw, -50vh) scale(0.8); }
        100% { transform: translate(10vw, 10vh) scale(1); }
    }

    .login-container {
        min-height: 100vh;
        width: 100vw;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        box-sizing: border-box;
    }

    .login-card {
        display: flex;
        flex-direction: row;
        width: 100%;
        max-width: 1000px;
        min-height: 600px;
        border-radius: 32px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 30px 60px rgba(100, 120, 150, 0.1); 
    }

    .login-left {
        flex: 1.2;
        background: #f0f4f8;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    
    .left-content {
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        /* Tarjeta de cristal */
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 50px 70px;
        border-radius: 32px;
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

    .login-right {
        flex: 1;
        padding: 80px 70px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: white;
        z-index: 2;
    }

    .welcome-text {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a202c;
        margin-bottom: 8px;
    }
    
    .subtitle-text {
        color: #718096;
        font-size: 1rem;
        margin-bottom: 40px;
    }

    /* Input Nativo estilizado como MudBlazor Outlined */
    .native-input {
        width: 100%;
        padding: 16px;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        font-size: 1.05rem;
        color: #2d3748;
        margin-bottom: 24px;
        transition: all 0.2s ease;
        background: transparent;
        font-family: inherit;
    }
    
    .native-input:focus {
        outline: none;
        border-color: #667eea;
        border-width: 2px;
        padding: 15px; /* offset 2px border */
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }

    .native-input::placeholder {
        color: #a0aec0;
    }

    .btn-filled {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 16px; 
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        width: 100%;
        padding: 16px;
        cursor: pointer;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .btn-filled:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(102, 126, 234, 0.4);
    }

    .brand-icon {
        font-size: 70px !important;
        margin-bottom: 15px;
        color: #667eea;
    }

    .brand-text {
        letter-spacing: 3px;
        font-weight: 700;
        color: #2d3748;
        font-size: 2rem;
    }

    @@media (max-width: 768px) {
        .login-card { flex-direction: column; max-width: 450px; }
        .login-left { padding: 50px 0; min-height: 250px; flex: none; }
        .login-right { padding: 40px 35px; }
    }
</style>

<div class="bg-blob-1"></div>
<div class="bg-blob-2"></div>

<div class="login-container">
    <div class="login-card">
        <!-- Panel Izquierdo (Limpio) -->
        <div class="login-left">
            <div class="left-content">
                <MudIcon Icon="@Icons.Material.Filled.Token" Class="brand-icon" />
                <MudText Typo="Typo.h4" Class="brand-text">NYX CRM</MudText>
            </div>
        </div>

        <!-- Panel Derecho (Formulario Minimalista para Minimal API) -->
        <div class="login-right">
            <h2 class="welcome-text">Bienvenido de vuelta</h2>
            <p class="subtitle-text">Ingresa tus credenciales para acceder a tu panel.</p>

            <form action="/login-endpoint" method="post" class="w-100">
                <input type="text" name="username" class="native-input" placeholder="Nombre de usuario" required autocomplete="username" />
                <input type="password" name="password" class="native-input" placeholder="Contraseña" required autocomplete="current-password" />

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <MudText Color="Color.Error" Typo="Typo.body2" Class="mb-4 text-center">@ErrorMessage</MudText>
                }

                <div class="d-flex justify-center mb-6">
                    <button type="submit" class="btn-filled">
                        Sign In
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string? ErrorMessage => Error;
}
