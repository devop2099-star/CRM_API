@page "/admin/fields"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "ADMIN_CRM,COORDINADOR,BACKOFFICE")]
@using Microsoft.AspNetCore.Authorization

<div class="zd-container">
    <div class="zd-header">
        <h1 class="zd-title">Add field</h1>
        <p class="zd-subtitle">Custom fields add more details to your customers. <a href="#" style="color: #007bff; text-decoration: none;">Learn about custom field types</a></p>
    </div>

    <div class="zd-grid">
        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><polyline points="9 11 12 14 22 4"></polyline></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Drop-down</div>
                <div class="zd-card-desc">Choose one option in a menu of choices</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"></polyline><line x1="9" y1="20" x2="15" y2="20"></line><line x1="12" y1="4" x2="12" y2="20"></line></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Text</div>
                <div class="zd-card-desc">Add a few words</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Checkbox</div>
                <div class="zd-card-desc">Add a yes or no option</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"></line><line x1="4" y1="15" x2="20" y2="15"></line><line x1="10" y1="3" x2="8" y2="21"></line><line x1="16" y1="3" x2="14" y2="21"></line></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Number</div>
                <div class="zd-card-desc">Enter a number with no decimal</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Multi-line</div>
                <div class="zd-card-desc">Add a few lines of text</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Date</div>
                <div class="zd-card-desc">Select a date from a calendar</div>
            </div>
        </div>

        <div class="zd-card">
            <div class="zd-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Decimal</div>
                <div class="zd-card-desc">Enter a number with a decimal</div>
            </div>
        </div>
        
        <div class="zd-card">
            <div class="zd-card-icon">
                <span style="font-size: 20px; font-weight: bold;">*</span>
            </div>
            <div class="zd-card-content">
                <div class="zd-card-title">Regex</div>
                <div class="zd-card-desc">Format regular expressions (Example: dates, URLs)</div>
            </div>
        </div>
    </div>
</div>
